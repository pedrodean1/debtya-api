# Copia a .env y rellena valores reales.
# Con NODE_ENV=production, scripts/validate-env.js exige ademas STRIPE_* y CRON_SECRET (ver script).

PORT=3000

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

PLAID_CLIENT_ID=YOUR_PLAID_CLIENT_ID
PLAID_SECRET=YOUR_PLAID_SECRET
PLAID_ENV=sandbox
PLAID_PRODUCTS=auth,transactions
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=
PLAID_ANDROID_PACKAGE_NAME=

CRON_SECRET=YOUR_CRON_SECRET
APP_BASE_URL=http://localhost:3000
# URL publica de la app (enlace de recuperacion de contraseña). Debe coincidir con Redirect URLs en Supabase Auth.
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_PRICE_ID_BETA_MONTHLY=YOUR_STRIPE_PRICE_ID
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PORTAL_CONFIG_ID=YOUR_STRIPE_PORTAL_CONFIG_ID

# Opcional: codigos separados por coma para activar plan sin pago (canje en app -> billing_subscriptions).
# Usa valores largos y aleatorios; no los compartas en publico.
DEBTYA_COMP_PROMO_CODES=
# Alternativa: un solo codigo sin comas.
DEBTYA_COMP_PROMO_CODE=

# Opcional: envío de código de verificación al registrarse (Resend). Dominio "from" debe estar verificado en Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=DebtYa <onboarding@resend.dev>
