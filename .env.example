# Copia a .env y rellena valores reales.
# Con NODE_ENV=production o RENDER=true, scripts/validate-env.js exige ademas SUPABASE_ANON_KEY, STRIPE_* y CRON_SECRET (ver script).

PORT=3000

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

PLAID_CLIENT_ID=YOUR_PLAID_CLIENT_ID
PLAID_SECRET=YOUR_PLAID_SECRET
PLAID_ENV=sandbox
PLAID_PRODUCTS=auth,transactions
PLAID_COUNTRY_CODES=US
PLAID_REDIRECT_URI=
PLAID_ANDROID_PACKAGE_NAME=

# Method Fi (liabilities / pagos futuros al acreedor). Opcional: sin clave, /method/* mutante responde 503.
# Clave API: METHOD_API_KEY, DEBTYA_METHOD_API_KEY, METHODFI_API_KEY, METHOD_FI_API_KEY, METHOD_SECRET_KEY, METHOD_SECRET.
METHOD_API_KEY=
# Entorno: METHOD_ENV, DEBTYA_METHOD_ENV, METHODFI_ENV (production | sandbox | dev).
METHOD_ENV=production
# Version cabecera: METHOD_API_VERSION, DEBTYA_METHOD_API_VERSION, METHODFI_API_VERSION.
METHOD_API_VERSION=2025-12-01

CRON_SECRET=YOUR_CRON_SECRET
# Puede ser el front (www); el enlace corto de reset usa el Host de la peticion a la API, no solo este valor.
APP_BASE_URL=http://localhost:3000
# URL publica donde corre ESTA API (fetch + enlaces /auth/recover en el correo + cabecera Debtya-Api-Base para el navegador).
# Obligatoria si el HTML se sirve desde www estatico y la API en otro host (p. ej. Render).
# DEBTYA_PUBLIC_API_URL=https://debtya-api.onrender.com
# URL publica de la app (redirect despues del reset en Supabase). Debe coincidir con Redirect URLs en Supabase Auth.
# En Render/produccion NO uses localhost aqui: si no, el enlace de reset abrira localhost en el navegador del usuario.
# redirect_to de Supabase (recovery) ya no prioriza solo FRONTEND_URL/www: usa DEBTYA_PUBLIC_API_URL / host de la peticion cuando aplica.
# Flujo recomendado: POST /auth/recover redirige a la MISMA API en /auth/reset-password (HTML generado en servidor).
# En Supabase SQL Editor ejecutar si aun no:
#   sql/add_password_reset_shortlinks_email_user.sql
#   sql/create_password_reset_finish.sql
FRONTEND_URL=http://localhost:5173
# Opcional: dominio del enlace CORTO del correo (/auth/recover?...). Debe ser la URL publica de ESTA API (donde existe /auth/recover).
# Si el front vive en www y la API en otro host (p. ej. api.debtya.com), pon aqui la API o el shortlink abrira el sitio estatico y no Node.
# PASSWORD_RESET_LINK_BASE=https://api.tudominio.com
# Opcional: URL publica post-reset (redirect_to en Supabase). Prioridad maxima; evita localhost si el resto de env esta mal.
# DEBTYA_PASSWORD_RESET_PUBLIC_URL=https://www.debtya.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_PRICE_ID_BETA_MONTHLY=YOUR_STRIPE_PRICE_ID
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PORTAL_CONFIG_ID=YOUR_STRIPE_PORTAL_CONFIG_ID

# Opcional: codigos separados por coma para activar plan sin pago (canje en app -> billing_subscriptions).
# Usa valores largos y aleatorios; no los compartas en publico.
DEBTYA_COMP_PROMO_CODES=
# Alternativa: un solo codigo sin comas.
DEBTYA_COMP_PROMO_CODE=

# Opcional: envío de código de verificación al registrarse (Resend). Dominio "from" debe estar verificado en Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=DebtYa <onboarding@resend.dev>
