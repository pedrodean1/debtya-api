{
  "name": "debtya-api",
  "version": "1.0.0",
  "description": "DebtYa backend",
  "main": "server.js",
  "scripts": {
    "start": "node scripts/validate-env.js && node server.js",
    "dev": "node server.js",
    "smoke:local": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-test.ps1 -ApiBaseUrl http://localhost:3000",
    "smoke:local:intents": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-test.ps1 -ApiBaseUrl http://localhost:3000 -IncludePaymentIntents",
    "smoke:local:full": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-test.ps1 -ApiBaseUrl http://localhost:3000 -IncludePaymentIntents -IncludeAccountsDebtsRules",
    "validate:env": "node scripts/validate-env.js",
    "sql:apply:spinwheel-debts": "node scripts/apply-sql-file.mjs sql/add_debts_spinwheel_columns_if_missing.sql",
    "test": "node --test ./test/lib/validation.test.js ./test/lib/method-env.test.js ./test/lib/method-client.test.js ./test/lib/spinwheel-env.test.js ./test/lib/spinwheel-client.test.js ./test/lib/spinwheel-users.test.js ./test/lib/spinwheel-debt-import.test.js ./test/lib/spinwheel-payable-summary.test.js ./test/lib/spinwheel-payment-intents.test.js ./test/lib/spinwheel-payments-validate.test.js ./test/scripts/validate-env.test.js ./test/routes/payment-intents-routes.test.js ./test/routes/stripe-webhook-routes.test.js ./test/routes/spinwheel-routes.test.js",
    "security:preflight": "powershell -ExecutionPolicy Bypass -File ./scripts/security-preflight.ps1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "plaid": "^41.4.0",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "pg": "^8.14.1",
    "supertest": "^7.2.2"
  }
}
